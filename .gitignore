# ══════════════════════════════════════════════════════════════════════════════
#  OpenTether — .gitignore
#  v0.9.1
# ══════════════════════════════════════════════════════════════════════════════

# ── Go relay ──────────────────────────────────────────────────────────────────

# Compiled binaries (repo root and any subdirectory)
# Compiled binaries (repo root and any subdirectory)
relay-linux-amd64
relay-linux-arm64
relay-linux-*
relay/opentether
opentether-*
relay/...
relay/mock_android
*.exe
*.testgit rm --cached relay 2>/dev/null || true
git rm --cached opentether 2>/dev/null || true
git rm --cached '...' 2>/dev/null || true
git commit -m "chore: untrack compiled binaries"
*.out

# Module cache / vendor (use go mod download instead)
/vendor/
go.sum.bak

# Build artifacts
/dist/

# ── Android client ────────────────────────────────────────────────────────────

# SDK location — machine-specific, never commit
local.properties

# Gradle caches and build outputs
.gradle/
build/
app/build/
**/build/

# Generated asset files
app/src/main/assets/webkit/
app/.cxx/

# APK / AAB outputs — build fresh, never store binaries in git
*.apk
*.aab
*.ap_

# Signing keys — never commit
*.jks
*.keystore
*.pepk
keystore.properties
release-keystore.properties
upload-keystore.jks

# ProGuard
proguard/
*.pro.bak
*.mapping

# ── IDE ───────────────────────────────────────────────────────────────────────

# IntelliJ / Android Studio
.idea/
*.iml
*.iws
*.ipr
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/assetWizardSettings.xml
.idea/dictionaries
.idea/libraries
.idea/caches
.idea/modules.xml
.idea/navEditor.xml
.idea/deploymentTargetDropDown.xml

# VS Code
# Uncomment the next line if you don't want to share editor settings
.vscode/
*.code-workspace

# GoLand
*.goland
.goflags

# ── OS ────────────────────────────────────────────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~
.nfs*

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Secrets / credentials ─────────────────────────────────────────────────────
*.pem
*.p12
*.pk8
*.key
.env
.env.*
.envrc
secrets.properties
google-services.json
GoogleService-Info.plist

# ── Logs / network captures ───────────────────────────────────────────────────
*.log
*.pcap
*.pcapng
logcat.txt
adb.log

# ── Test & coverage outputs ───────────────────────────────────────────────────
test-results/
coverage/
*.cover
*.coverprofile
/tmp/

# ── USB / AOA build artifacts ─────────────────────────────────────────────────
# libusb pkg-config cache (generated on first build with -tags aoa)
pkg-config-cache/