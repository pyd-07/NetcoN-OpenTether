<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundDark"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="36dp">

        <!-- ── Header: app title ───────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="@string/app_name"
            android:textColor="@color/textPrimary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium" />

        <!-- ── Status row: dot · label · timer ───────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <View
                android:id="@+id/dotStatus"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_dot_status_idle" />

            <TextView
                android:id="@+id/tvConnectionStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/status_idle"
                android:textColor="@color/textSecondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvSessionTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00:00"
                android:textColor="@color/textTertiary"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:visibility="gone" />
        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════════════
             Stats section — GONE until VPN connects
             ══════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/statsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- ── Row 1: Download / Upload cards ───────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.OpenTether.Card.Stat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:text="@string/label_download"
                            android:textAllCaps="true"
                            android:textColor="@color/textMuted"
                            android:textSize="11sp"
                            android:letterSpacing="0.05" />
                        <TextView
                            android:id="@+id/tvDownloadSpeed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0"
                            android:textColor="@color/textPrimary"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-medium" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="MB/s"
                            android:textColor="@color/textTertiary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.OpenTether.Card.Stat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:text="@string/label_upload"
                            android:textAllCaps="true"
                            android:textColor="@color/textMuted"
                            android:textSize="11sp"
                            android:letterSpacing="0.05" />
                        <TextView
                            android:id="@+id/tvUploadSpeed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0"
                            android:textColor="@color/textPrimary"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-medium" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="MB/s"
                            android:textColor="@color/textTertiary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ── Row 2: Throughput chart ───────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.OpenTether.Card.Stat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="@string/label_throughput"
                        android:textAllCaps="true"
                        android:textColor="@color/textMuted"
                        android:textSize="11sp"
                        android:letterSpacing="0.05" />

                    <com.opentether.view.ThroughputChartView
                        android:id="@+id/chartView"
                        android:layout_width="match_parent"
                        android:layout_height="60dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="↑ upload"
                            android:textColor="@color/chartUpload"
                            android:textSize="10sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="↓ download"
                            android:textColor="@color/connectedGreen"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Row 3: Total ↓ / Total ↑ / RTT ──────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.OpenTether.Card.Stat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:text="@string/label_total_down"
                            android:textColor="@color/textTertiary"
                            android:textSize="10sp" />
                        <TextView
                            android:id="@+id/tvTotalDown"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 MB"
                            android:textColor="@color/textPrimary"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.OpenTether.Card.Stat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:text="@string/label_total_up"
                            android:textColor="@color/textTertiary"
                            android:textSize="10sp" />
                        <TextView
                            android:id="@+id/tvTotalUp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 MB"
                            android:textColor="@color/textPrimary"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.OpenTether.Card.Stat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:text="@string/label_rtt"
                            android:textColor="@color/textTertiary"
                            android:textSize="10sp" />
                        <TextView
                            android:id="@+id/tvRtt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="— ms"
                            android:textColor="@color/textPrimary"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ── Row 4: Active connections ────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.OpenTether.Card.Stat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_active_connections"
                            android:textAllCaps="true"
                            android:textColor="@color/textMuted"
                            android:textSize="11sp"
                            android:letterSpacing="0.05" />
                        <TextView
                            android:id="@+id/tvActiveConnCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/textPrimary"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <!-- Rows injected programmatically from MainActivity -->
                    <LinearLayout
                        android:id="@+id/llConnections"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout><!-- end statsContainer -->

        <!-- ── Idle: quick-start hint ────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/hintCard"
            style="@style/Widget.OpenTether.Card.Stat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="Quick start"
                    android:textColor="@color/textPrimary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="4dp"
                    android:text="1. Connect your phone over USB and enable USB debugging.\n2. On the PC run: sudo ./relay &amp;&amp; adb reverse tcp:8765 tcp:8765\n3. Tap Start VPN below and accept the system dialog."
                    android:textColor="@color/textSecondary"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Start VPN (idle state) ───────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStart"
            style="@style/Widget.OpenTether.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/action_start" />

        <!-- ── Stop VPN (connected state) ──────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStop"
            style="@style/Widget.OpenTether.Button.Stop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/action_stop"
            android:visibility="gone" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>