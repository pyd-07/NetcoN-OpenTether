<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ── Stat cards (download, upload, totals, chart, connections) ─────── -->
    <style name="Widget.OpenTether.Card.Stat" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/cardDark</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- ── Primary action button (Start VPN) ──────────────────────────────── -->
    <style name="Widget.OpenTether.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">52dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/buttonText</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="elevation">0dp</item>
        <item name="rippleColor">@color/primaryDark</item>
    </style>

    <!-- ── Stop VPN button — identical tint (matches HTML #3C3489) ─────────── -->
    <style name="Widget.OpenTether.Button.Stop" parent="Widget.OpenTether.Button.Primary"/>

    <!-- ── Legacy styles kept so old layout references compile ──────────────── -->
    <style name="Widget.OpenTether.Card.Hero" parent="Widget.OpenTether.Card.Stat"/>
    <style name="Widget.OpenTether.Card.Status" parent="Widget.OpenTether.Card.Stat"/>
    <style name="Widget.OpenTether.Card.Info" parent="Widget.OpenTether.Card.Stat"/>
    <style name="Widget.OpenTether.Button.Secondary" parent="Widget.OpenTether.Button.Primary"/>

</resources>