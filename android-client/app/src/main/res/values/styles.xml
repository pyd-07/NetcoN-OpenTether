<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.OpenTether.Card.Hero" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">28dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/outline</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.OpenTether.Card.Status" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surfaceSoft</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/outline</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.OpenTether.Card.Info" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surfaceWarm</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/outline</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.OpenTether.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">56dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="cornerRadius">18dp</item>
        <item name="elevation">0dp</item>
        <item name="rippleColor">@color/chipBg</item>
    </style>

    <style name="Widget.OpenTether.Button.Secondary" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">56dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textSize">16sp</item>
        <item name="backgroundTint">@color/surface</item>
        <item name="cornerRadius">18dp</item>
        <item name="elevation">0dp</item>
        <item name="rippleColor">@color/chipBg</item>
        <item name="strokeColor">@color/outline</item>
        <item name="strokeWidth">1dp</item>
    </style>
</resources>
