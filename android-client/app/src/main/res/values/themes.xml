<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.OpenTether" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primaryDark</item>
        <item name="colorSecondary">@color/connectedGreen</item>
        <item name="colorOnPrimary">@color/buttonText</item>
        <item name="colorOnSecondary">@color/textPrimary</item>
        <item name="colorSurface">@color/cardDark</item>
        <item name="colorOnSurface">@color/textPrimary</item>
        <item name="android:windowBackground">@color/backgroundDark</item>
        <item name="android:statusBarColor">@color/backgroundDark</item>
        <item name="android:navigationBarColor">@color/backgroundDark</item>
        <!-- Keep status-bar icons light (text on dark bg) -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>