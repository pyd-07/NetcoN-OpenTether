<?xml version="1.0" encoding="utf-8"?>
<!--
    Single source of truth for all color tokens.

    styles.xml deliberately contains NO <color> elements — only <style>.
    Every @color reference in layouts, drawables, and themes resolves here.
-->
<resources>
    <!-- Backgrounds -->
    <color name="backgroundDark">#0D1117</color>
    <color name="backgroundTop">#0D1117</color>
    <color name="backgroundBottom">#0D1117</color>
    <color name="surfaceDark">#161B22</color>
    <color name="surfaceAlt">#1C2128</color>

    <!-- Brand / action -->
    <color name="primary">#1F6FEB</color>
    <color name="primaryDark">#1F6FEB</color>
    <color name="secondary">#58A6FF</color>

    <!-- Status / chart -->
    <color name="connectedGreen">#2EA043</color>
    <color name="chartUpload">#58A6FF</color>
    <color name="warningYellow">#D29922</color>
    <color name="errorRed">#F85149</color>

    <!-- Text -->
    <color name="textPrimary">#E6EDF3</color>
    <color name="textSecondary">#8B949E</color>
    <color name="textTertiary">#6E7681</color>
    <color name="textMuted">#6E7681</color>
    <color name="buttonText">#E6EDF3</color>

    <!-- Surfaces / glows -->
    <color name="cardDark">#161B22</color>
    <color name="glowBlue">#221F6FEB</color>
    <color name="chipBg">#1F2937</color>

    <!-- Borders -->
    <color name="outline">#30363D</color>
</resources>